# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/

OPENAI_API_KEY=your-openai-api-key-here

# Optional: Specify model (default is gpt-5-mini)
# MODEL=gpt-5-mini

# Processing Configuration
# Maximum concurrent API requests (default: 5)
MAX_CONCURRENT_REQUESTS=5

# Receipts per Excel file (default: 10)
RECEIPTS_PER_FILE=10

# Income tax advance rate (מקדמות מס הכנסה), in percent. Optional.
# INCOME_TAX_ADVANCE_RATE=12

# The business's own tax ids (owner, spouse, company ח.פ), comma-separated.
# The audit flags any receipt whose vendor_id equals one of these - it means the
# extractor mistook your own id for the vendor's. Optional; personal - keep only
# in your real .env, never commit real values.
# OWN_TAX_IDS=000000000,111111111